{
  "name": "taskwheel-rails",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@headlessui/react": "^1.7.0",
    "@heroicons/react": "^2.0.0",
    "@rails/actioncable": "^7.1.0",
    "@rails/activestorage": "^7.1.0",
    "@rails/ujs": "^7.1.0",
    "axios": "^1.6.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-calendar": "^6.0.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "postcss-import": "^15.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-ruby": "^3.0.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "prepare": "husky install",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint app/javascript --ext .ts,.tsx",
    "lint:fix": "eslint app/javascript --ext .ts,.tsx --fix",
    "format": "prettier --write 'app/javascript/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'app/javascript/**/*.{ts,tsx,css}'"
  },
  "lint-staged": {
    "app/javascript/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
