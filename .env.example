RAILS_ENV=development
DATABASE_URL=postgresql://postgres:password@db:5432/task_wheel_development
NODE_ENV=development

# Google OAuth2 (Devise OmniAuth)
# Google Cloud ConsoleでWebアプリのOAuthクライアントを作成し設定してください
# 承認済みリダイレクトURI: http://localhost:3000/users/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Password reset mail settings (development with Gmail SMTP)
APP_BASE_URL=http://localhost:3000
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=gmail.com
SMTP_USER_NAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true